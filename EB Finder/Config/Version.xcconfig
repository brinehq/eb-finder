// App version values. The version is calendar-based and stamped automatically
// at build time by EB Finder/ci_scripts/ci_post_clone.sh — there is nothing to bump or tag:
//
//   MARKETING_VERSION         CFBundleShortVersionString = the UTC build date,
//                             e.g. 2026.6.4 (Xcode Cloud overwrites this).
//   CURRENT_PROJECT_VERSION   CFBundleVersion = Xcode Cloud's build number
//                             ($CI_BUILD_NUMBER), which makes same-day builds
//                             unique.
//
// The values committed here are only the fallback for a plain local build (which
// never runs the CI hook); every shipped build is stamped fresh. These keys live
// here — not in project.yml — so they resolve at build time with no project
// regeneration. Both targets inherit them via the project's base configuration
// (see `configFiles` in project.yml).

MARKETING_VERSION = 2026.6.4
CURRENT_PROJECT_VERSION = 1

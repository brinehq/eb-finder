    "license.body.grant" : {
      "comment" : "License page — MIT grant paragraph (plain-language summary).",
      "extractionState" : "manual",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der gives hermed tilladelse, gratis, til enhver, der får en kopi af denne software, til at bruge, kopiere, ændre og distribuere den uden begrænsning."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permission is hereby granted, free of charge, to anyone obtaining a copy of this software to use, copy, modify and distribute it without restriction."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Täten myönnetään maksutta lupa kenelle tahansa, joka hankkii kopion tästä ohjelmistosta, käyttää, kopioida, muokata ja jakaa sitä rajoituksetta."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Det gis herved tillatelse, vederlagsfritt, til enhver som skaffer seg en kopi av denne programvaren til å bruke, kopiere, endre og distribuere den uten begrensning."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tillstånd beviljas härmed, utan kostnad, till var och en som erhåller en kopia av denna programvara att använda, kopiera, modifiera och distribuera den utan begränsning."
          }
        }
      }
    },
    "license.body.warranty" : {
      "comment" : "License page — warranty disclaimer line.",
      "extractionState" : "manual",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Softwaren leveres, »som den er«, uden nogen form for garanti."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The software is provided \"as is\", without warranty of any kind."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ohjelmisto tarjotaan ”sellaisenaan”, ilman minkäänlaista takuuta."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Programvaren leveres «som den er», uten noen form for garanti."

    "about.disclaimer.body" : {
      "comment" : "About page — independence disclaimer body.",
      "extractionState" : "manual",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "EB Finder er ikke officielt tilknyttet SAS – Scandinavian Airlines eller EuroBonus. Det er et uafhængigt projekt og henter partnerdata via LoyaltyKeys offentlige API."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "EB Finder is not officially affiliated with SAS – Scandinavian Airlines or EuroBonus. It is an independent project and fetches partner data via LoyaltyKey's public API."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "EB Finder ei ole virallisesti sidoksissa SAS – Scandinavian Airlinesiin tai EuroBonukseen. Se on riippumaton projekti ja hakee kumppanitiedot LoyaltyKeyn julkisen rajapinnan kautta."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "EB Finder er ikke offisielt tilknyttet SAS – Scandinavian Airlines eller EuroBonus. Det er et uavhengig prosjekt og henter partnerdata via LoyaltyKeys offentlige API."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "EB Finder är inte officiellt anslutet till SAS – Scandinavian Airlines eller EuroBonus. Tjänsten är ett oberoende projekt och hämtar partnerdata via LoyaltyKeys publika API."
          }
        }
      }
    },

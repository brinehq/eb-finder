    "onboarding.permissions.detail" : {
      "comment" : "Body on the 'allow all websites' step, including the privacy reassurance.",
      "extractionState" : "manual",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Giv EB Finder adgang til alle domæner — ellers kan partnere på nogle sider blive overset. Vi sammenligner kun webstedets domænenavn med partnerlisten; intet andet læses, spores eller gemmes."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Give EB Finder access to all domains — otherwise partners on some pages may be missed. We only compare the site's domain name against the partner list; nothing else is read, tracked or stored."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anna EB Finderille pääsy kaikkiin verkkotunnuksiin — muuten kumppanit joillakin sivuilla voivat jäädä huomaamatta. Vertaamme vain sivuston verkkotunnusta kumppaniluetteloon; mitään muuta ei lueta, seurata tai tallenneta."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gi EB Finder tilgang til alle domener — ellers kan partnere på enkelte sider bli oversett. Vi sammenligner bare nettstedets domenenavn mot partnerlisten; ingenting annet leses, spores eller lagres."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ge EB Finder åtkomst till alla domäner — annars kan partners på vissa sidor missas. Vi jämför bara webbplatsens domännamn mot partnerlistan; ingenting annat läses, spåras eller sparas."
          }
        }
      }
    },

    "onboarding.enable.detail" : {
      "comment" : "Step shown when the extension is installed but switched off in Safari.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open Safari extension settings and switch on EB Finder so we can spot SAS EuroBonus partner shops while you browse."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öppna Safaris tilläggsinställningar och aktivera EB Finder, så vi kan hitta SAS EuroBonus partnerbutiker när du surfar."
          }
        }
      }
    },

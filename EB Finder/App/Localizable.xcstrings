    "onboarding.permissions.detail.ios" : {
      "comment" : "iOS micro-instruction for granting all-websites access. Lands in Settings → Safari → Extensions → EB Finder.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open Safari settings, then under **Permissions** tap **All Websites** → **Allow**. Visit any page in Safari and we'll confirm automatically."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öppna Safari-inställningar, och tryck sedan under **Behörigheter** på **Alla webbplatser** → **Tillåt**. Besök valfri sida i Safari så bekräftar vi automatiskt."
          }
        }
      }
    },
    "onboarding.permissions.detail.macos" : {
      "comment" : "macOS micro-instruction for granting all-websites access. Lands in Safari → Settings → Extensions → EB Finder.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open Safari settings, then set **Other Websites** to **Allow**. Visit any page in Safari and we'll confirm automatically."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öppna Safari-inställningar och ställ in **Andra webbplatser** på **Tillåt**. Besök valfri sida i Safari så bekräftar vi automatiskt."
          }
        }
      }
    },
    "onboarding.permissions.secondary" : {
      "comment" : "Escape-hatch button on the permissions step so users are never trapped if live detection lags.",

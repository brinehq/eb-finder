    "onboarding.enable.detail" : {
      "comment" : "Body on the 'turn on the extension' step.",
      "extractionState" : "manual",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slå EB Finder til i Safari-indstillingerne, så vi kan finde EuroBonus-partnere, mens du surfer."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Switch on EB Finder in Safari settings so we can spot EuroBonus partners while you browse."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ota EB Finder käyttöön Safarin asetuksissa, jotta voimme löytää EuroBonus-kumppanit selatessasi."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slå på EB Finder i Safari-innstillingene slik at vi kan finne EuroBonus-partnere mens du surfer."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slå på EB Finder i Safari-inställningarna så att vi kan hitta EuroBonus-partners medan du surfar."
          }
        }
      }
    },

    "onboarding.permissions.button" : {
      "comment" : "CTA on the 'grant website access' step.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open Safari Settings"

    "onboarding.permissions.detail" : {
      "comment" : "Body on the 'allow all websites' step, including the privacy reassurance.",
      "extractionState" : "manual",
      "localizations" : {
        "base" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Give EB Finder access to all domains — otherwise partners on some pages may be missed. We only compare the site's domain name against the partner list; nothing else is read, tracked or stored."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Give EB Finder access to all domains — otherwise partners on some pages may be missed. We only compare the site's domain name against the partner list; nothing else is read, tracked or stored."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ge EB Finder åtkomst till alla domäner — annars kan partners på vissa sidor missas. Vi jämför bara webbplatsens domännamn mot partnerlistan; ingenting annat läses, spåras eller sparas."
          }
        }
      }
    },

{
  "manifest_version": 3,
  "version": "0.0.0",
  "default_locale": "en",

  "name": "__MSG_extension_name__",
  "description": "__MSG_extension_description__",
  "author": "Brine AB",
  "homepage_url": "https://www.brine.co",

  "icons": {
    "48": "images/icon-48.png",
    "96": "images/icon-96.png",
    "512": "images/icon-512.png",
    "1024": "images/icon-1024.png"
  },

  "host_permissions": ["https://onlineshopping.loyaltykey.com/*"],

  "permissions": ["storage", "activeTab"],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["tokens.css", "content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
